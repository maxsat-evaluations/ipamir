  unsigned int greatestPowerOfTwoLessThan(unsigned int n)
  {
	unsigned int k=1;
	while (k<n)
	  { k <<= 1; }

	return (k>>1);
  }

  // Definition
  quantom::configureset Quantom::quantom_configs;

  // Constructor.
  Quantom::Quantom ( void ) :
	m_control(NULL),
    m_cores(),
	m_blackmagic(1),
	m_cpulimit(0.0),
	m_starttime(0.0),
	m_Constraints(),
	m_pendingConstraints(),
	m_softvariables(),
	m_softclauses(),
	m_triggerVars(),
	m_low(-1),
	m_high(-1),
	m_preprocess(false),
	m_maxinprocess(false),
	m_skipinitbychance(false),
	m_stacksize(0),
	m_globalPropertyTrigger(),
	m_softstack(),
	m_dummyvar(0),
	m_splittedWidth(8),
	m_bypassGrid(4),
	m_horizontalwidth(4),
	m_setCSC(false),
	m_setTrigger(false),
	m_maxWidth(0),
	m_skipped(0),
	m_comparator(0),
	m_verticalbypasses(0),
	m_horizontalbypasses(0)
  {

    // Initialize "m_control".
    m_control = new Control();
	
    // Initialize a new QBF solving core.
	unsigned int corenumber = quantom_configs.initconfigs;
	assert(corenumber > 0 );
	m_cores.resize(corenumber);
	for( unsigned int i = 0; i != corenumber; ++i )
	  { m_cores[i] = new Core(m_control); }

	m_softstack.push_back(0);
	m_blackmagic = corenumber; 
  }
   
  // Destructor.
  Quantom::~Quantom (void) 
  { 
	for( unsigned int i = 0; i != m_cores.size(); ++i )
	  { delete m_cores[i]; }

	delete m_control;
  }

