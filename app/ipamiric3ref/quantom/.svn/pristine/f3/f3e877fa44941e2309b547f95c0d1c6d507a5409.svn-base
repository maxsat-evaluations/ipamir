# This line for non-combined version
AM_CPPFLAGS = -I$(top_srcdir)/include

noinst_LIBRARIES      = libquantom.a
libquantom_a_SOURCES  = quantom.cpp cquantom.cpp
#libquantom_a_SOURCES  = quantom.cpp
#bin_PROGRAMS          = quantom bmcexample
bin_PROGRAMS          = quantom
quantom_SOURCES       = main.cpp
quantom_LDADD         = libquantom.a

#bmcexample_SOURCES    = bmc_example.cpp
#bmcexample_LDADD      = libquantom.a
#bmcexample_LDFLAGS    = -g

#32 bit version
#CPPFLAGS              = -m32 
#quantom_LDFLAGS       = -m32 
quantom_LDFLAGS       = -g
#quantom_LDFLAGS       = -g -m32 

clean-local:
	rm -r -f *~
	rm -r -f *.gc*	

distclean-local: 	
	rm -r -f *~
	rm -r -f *.gc*
	rm -r -f Makefile.in 
