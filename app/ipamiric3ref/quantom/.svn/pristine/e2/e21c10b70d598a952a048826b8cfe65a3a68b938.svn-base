#ifdef COMBSOLVER
  /* needed for export to aigsolve 
	 collect all learned clauses from aigsolve */
  struct Implications
  {
	std::vector< std::pair<unsigned int, unsigned int > > units;
	std::map< unsigned int, unsigned int > binimpl;
	std::map< unsigned int, pointToClause* > naryimpl;
	std::vector< unsigned int > pseudoimpl;
	int backtracklevel;
	bool unitclause;
	
	Implications(unsigned int level) :
	  units(),
	  binimpl(),
	  naryimpl(),
	  pseudoimpl(),
	  backtracklevel(level),
	  unitclause(false)
	{}
  };
#endif
  
  // removes universal bit flag from "lit"
  inline unsigned int Lit ( unsigned int lit ) { return (lit&AUNIFLAG); }

