  private:

	/*some functions for setting flag bits*/

	inline void setUniFlag ( unsigned int& lit ) const 
	{
	  assert( (Lit(lit)>>1) < q_level.size() );

	  if( (q_level[Lit(lit)>>1] & 1 ) == 0 )
		{ lit |= UNIFLAG; }
	}
	
	inline unsigned int getUniFlag ( unsigned int lit ) const 
	{
	  assert( (Lit(lit)>>1) < q_level.size() );

	  if( (q_level[Lit(lit)>>1] & 1 ) == 0 )
		{ lit |= UNIFLAG; }
	  return lit;
	}

	inline bool isDecision( unsigned int lit ) const
	{ return ( (q_reason[Lit(lit)>>1] & 7) == 0 ); }

	inline bool isUnit ( unsigned int lit ) const
	{ return ( ( q_reason[Lit(lit)>>1] & 1 ) != 0 ); }

	/* is the literal an unit forced by an original clause? */
	inline bool isOrgUnit( unsigned int lit ) const 
	{ return ( ( q_reason[Lit(lit)>>1] ^ 1 ) == 0 ); }

	inline bool isPure ( unsigned int lit ) const
	{ return ( ( q_reason[Lit(lit)>>1] & 2 ) != 0 ); }

	bool isEPure ( unsigned int lit ) const
	{ 
	  if( !isUniversal(lit) )
		{ return isPure(lit); }
	  else
		{ return false; }
	}

	bool isUPure ( unsigned int lit ) const
	{
	  if( isUniversal(lit) )
		{ return isPure(lit); }
	  else
		{ return false; }
	}

	inline bool isDC ( unsigned int lit ) const
	{ return ( ( q_reason[Lit(lit)>>1] & 4 ) != 0 ); }

	bool isEDC ( unsigned int lit ) const
	{
	  if( !isUniversal(lit) )
		{ return isDC(lit); }
	  else
		{ return false; }
	}
	 
	bool isUDC ( unsigned int lit ) const
	{ 
	  if( isUniversal(lit) )
		{ return isDC(lit); }
	  else
		{ return false; }
	}


	inline bool isPureOrDC( unsigned int lit ) const
    { return ( ( q_reason[Lit(lit)>>1] & 6 ) != 0 ); }

	bool isEPureOrDC( unsigned int lit ) const
	{ return isEPure(lit); }

	bool isUPureOrDC( unsigned int lit ) const
	{ return isUPure(lit); }

	inline void setUnit ( unsigned int lit )
	{ 
	  assert( q_reason[Lit(lit)>>1] == 0 );
	  q_reason[Lit(lit)>>1] = 1; 
#ifdef EXDEBUG
	  std::cout << "setunit: " << getLit(lit) << " = " << q_reason[Lit(lit)>>1] << std::endl;
#endif
	}

	inline void setLearnedUnit( unsigned int lit )
	{
	  assert( q_reason[Lit(lit)>>1] == 0 ); 
	  q_reason[Lit(lit)>>1] = 9;
	}

	inline void setPure ( unsigned int lit )
	{ 
	  q_reason[Lit(lit)>>1] = 2; 
#ifdef EXDEBUG
	  std::cout << "setpure: " << getLit(lit) << " = " << q_reason[Lit(lit)>>1] << std::endl;
#endif
	}

	inline void setDC ( unsigned int lit )
	{ 
	  q_reason[Lit(lit)>>1] |= 4; 
#ifdef EXDEBUG
	  std::cout << "setdc: " << getLit(lit) << " = " << q_reason[Lit(lit)>>1] << std::endl;
#endif
	}
	
	inline void resetDC ( unsigned int lit )
	{
	  q_reason[Lit(lit)>>1] &= 3;
#ifdef EXDEBUG
	  std::cout << "resetdc: " << getLit(lit) << " = " << q_reason[Lit(lit)>>1] << std::endl;
#endif
	}

	inline void unsetReason ( unsigned lit )
	{ q_reason[Lit(lit)>>1] = 0; }


