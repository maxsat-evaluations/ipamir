	/* constructor */
	Core(const Core& );
	Core& operator=(const Core& );

    // Each core has a pointer to the "Control" object.
    Control* m_control;

	/* data members */

	// A flag indicating whether we have been able to deduce the empty clause.
	// In particular important for the increemntal mode to distinguish between
	// "unsatisfiable" and "unsatisfiable under assumptions". 
	bool m_emptyClause;

	// Store the return result of the solver
	unsigned int m_result;

	// The total runtime 
	double m_runtime;

	// The current number of variables.
	unsigned int m_variables; 

	// Maximum original var (variables except auxiliary variables for maximization)
	unsigned int m_maxorgvar;

	// The number of decisions made so far.
	unsigned int m_decisions; 

	// The number of BCP operations performed so far. 
	unsigned int m_bcps; 

	// The number of conflicts encountered so far.
	unsigned int m_conflicts; 

	// The number of restarts performed so far.
	unsigned int m_restarts;
	unsigned int m_restartAttempts;
	unsigned int m_currentRestarts;

	// The number of database simplifications performed so far.
	unsigned int m_simplifications;
	unsigned int q_simplifications;

	// The number of literals implied on dl 0 at the last simplification step
	unsigned int m_lastSimplifyCount;

	int q_slbd;

	// The (partial) variable assignment.
	std::vector<unsigned char> m_assignment;

	// Store preferences for lits.
	std::vector<unsigned int> m_polarity;

	// Store weights for lits.
	std::vector<unsigned int> m_weight;

	// The assignment cache.
	std::vector<unsigned char> m_cache;

	double m_agility;
	bool m_useAgility;
	double m_agilityThreashold;

	// The decision level on which a particular literal has been assigned.
	std::vector<unsigned int> m_level; 

	// For each variable we store its activity.
	std::vector<double> m_activity;  
	std::vector<unsigned int > m_activity2;
	std::vector<unsigned int > m_activity3;

	// For each variable we store whether it is 
	// -- an implication forced by a non-binary clause (m_forcing != NULL, m_binForcing == 0), 
	// -- an implication forced by a binary clause (m_forcing == NULL, m_binForcing != 0), or
	// -- a decision (m_forcing == NULL, m_binForcing == 0). 
	std::vector<unsigned int*> m_forcing;
	std::vector<unsigned int> m_binForcing;

	// For each literal we store a vector of pairs (clause pointer, blocking literal) to represent 
	// in which clause a particular literal currently serves as a watched literal.
	// For quantom:
	// Only a clauseobject will be stored, which contains the watched literals
	std::vector<std::vector< pointToClause* > > m_watches;

	// Store watched literals for learned clauses separatly
	std::vector<std::vector< pointToClause* > > m_learnedWatches;

	// Store watched literals for cubes separatly
	std::vector<std::vector< pointToClause* > > q_cubeWatches;

	// For each literal we store a vector of literals to represent in which binary clauses it occurs.
	// (x, y) --> m_binWatches[x] = {...,y,...} and m_binWatches[y] = {...,x,...}.
	std::vector<std::vector<unsigned int> > m_binWatches;

	// Stores for each variable the index at which the learned clauses starts.
	std::vector< unsigned int > m_binWatchesLearnedIndex;

	// Some variable activity related variables.
	double m_incVarActivity;
	double m_varActMultiplier;

	// The current decision level.
	unsigned int m_decisionLevel; 

	// The root level of the current (incremental) run.
	unsigned int m_rootLevel;

	// The decision stack.
	std::vector<unsigned int> m_decisionStack;

	// Some decision stack related variables.
	unsigned int m_dsEndIndex;
	unsigned int m_dsImplIndex;
	unsigned int q_dsPropIndex;
	bool m_newDecision;

	// Some conflict analysis related variables. Setting "m_binConflict" to (x, y) 
	// represents, that we have a conflict due to the binary conflicting clause (x, y).
	unsigned int m_binConflict[2];

	// The luby shift constant
	unsigned int m_lubyShift;

	// Some restart / clause deletion related variables.
	unsigned int m_nxtRestarti;
	unsigned int m_nxtRestarto;
	unsigned int m_innercounter;
	unsigned int m_outercounter;
	unsigned int m_nxtRestart;

	unsigned int m_ccs;

	// Some decision heuristic related variables.
	bool m_decVarSign;
	bool m_switchVarSign;

	// The satisfying variable assignment of the outermost quant
	// level(in case the CNF formula is satisfiable; otherwise
	// "m_model" might contain invalid data).
	std::vector<unsigned int> m_model;

	// last conflict clause
	std::vector<unsigned int> m_conflictClause;

	// Storing temporaly solution cubes
	std::vector< unsigned int > q_solutioncube;

	// For quantom: we have an extra object for clauses
	std::vector< pointToClause* > m_clauseDatabase;

	// Store solution cubes - have to be treated like clauses (dual)
	std::vector< pointToClause* > q_solutionDatabase;

	// Open clause id's
	std::vector< unsigned int > m_openIDs;

	// candiates for simplification
	std::vector< pointToClause* > m_candidates;

	bool q_multiplexed;

	// Some statistics of the formula
	unsigned int m_literals;
	unsigned int m_clauses;
	unsigned int m_clausesBinary;
	unsigned int m_clausesStatic;
	unsigned int m_clausesStaticBinary;
	unsigned int m_clausesDynamic;
	unsigned int m_clausesDynamicBinary;
	unsigned int m_cubes;
	unsigned int m_clauselength;
	unsigned int m_clauseIDs;
   	double m_avgGlobalDL;
	double m_avgLocalDL;
	unsigned int m_avgGlobalBTlevel;
	unsigned int m_avgLocalBTlevel;
	unsigned int q_solutions;
	unsigned int q_purelits;
	unsigned int q_dontcare;
	//  0: touched bin
	//  1: conflicts by bin
	//  2: implication by bin
	//  3: touched learned bin
	//  4: conflicts by learned bin
	//  5: implication by learned bin
	//  6: touched by nary clause
	//  7: conflicts by nary clause
	//  8: implication by nary clause
	//  9: touched learned nary clause
	// 10: conflicts by learned nary clause
	// 11: implication by learned nary clause
	// 12: touched cube
	// 13: conflicts by cube
	// 14: implication by cube
	std::vector< unsigned int > m_bcpstats;

	bool m_forward;

	/* store reason for decision:
	   0x0 : not assigned or branched literal
	   0x1 : unit literal
	   0x2 : pure literal
	   0x4 : don't care literal
	   needed for pure literal detection + conflict/solution analysis
	*/
	std::vector< unsigned int > q_reason;

	//current quantlevel for decision
	unsigned int q_decision;

	// Maximum q_level
	unsigned int q_maxqlevel;

	//minimum quant level;
	unsigned int q_minqlevel;

	// Maximum Radix, needed by sort algorithms
	unsigned int q_maxradix;

	unsigned int q_cachedImplIndex;
	
	// The variable ordering used by the decision heuristic.
	// For quantom we need a ordering for every quantlevel
	std::vector< VarHeap<double>* > q_varOrder;
	std::vector< VarHeap<unsigned int>* > q_varOrder2;

	// average lbd values for clauses and cubes
	unsigned int m_tlbd;
	unsigned int m_ttlbd;
	bool q_skiplearning;
	bool q_togglelearning;
	
	// Some parameters for the heuristics
	unsigned int m_ip;
	unsigned int m_decHeu;
	unsigned int m_restartHeu;
	bool m_resetHeu;
	bool m_cacheswap;
	bool m_lhbr;
	bool q_mincube;
	bool q_subsumption;
	bool q_nextsubsumption;
	bool q_upla;
	bool q_varelim;
	bool q_quantmerge;
	unsigned int m_recalcDecHeu;
	unsigned int m_lhbrclauses;
	unsigned int q_solutionorder;
	unsigned int q_soltype;
 
	// quantlevel of each variable 
	// odd: existential, even: universal, starting with 1
	std::vector< unsigned int > q_level;

	// occurencelist pointing to corresponding clauses of the literals
	// occurencelists exists only for the original clause set.
	std::vector< std::vector< pointToClause* > > q_occur;

	// Preprocessor data structures

	// Don't touch list
	std::vector< bool > m_donttouch;

	// did we deleted a variable ?
	std::vector< bool > q_deleted;

	// did we have replaced a variable in preprocessor? 
    // the replacing literal is given for each variable, "0" if variable was not replaced
    // information needed for model
	std::vector< std::vector< unsigned int > > q_replaces;

	// Literals by level map
	std::vector< std::vector< unsigned int > > q_litbylevel;

	// Store assumptions
	std::vector< unsigned int > q_assumptions;

	// Status variables
	bool q_solve;
	bool q_prepro;
	bool q_inpro;
	bool q_newunit;

	bool q_refreshVarorder;
	std::vector< unsigned int > q_elimclauses;

	// Pre/In-prpocessor statistics
	unsigned int q_inprocessings;
	unsigned int q_subsumptions;
	unsigned int q_selfsubsumptions;
	unsigned int q_monolits;
	unsigned int q_dclits;
	unsigned int q_cons;
	unsigned int q_equiv;
    unsigned int q_uplacons;
    unsigned int q_uplaequiv;
	unsigned int q_reslits;	
	unsigned int q_mergedLevels;
	unsigned int q_deletedLevels;
	unsigned int q_unitprop;

	// Lifting mode?
	unsigned int q_liftingmode;

	// Backtracklevel for lifting
	unsigned int q_backtracklevel;

	// The cube units
	std::vector< unsigned int > q_unitcubes;

	// Verbosity value
	unsigned int m_verbosity;

#ifdef COMBSOLVER
	/* some data for combined solver */

	// number of orginal n-nary clauses
	unsigned int e_orgclauses;
 	unsigned int e_counter;
	unsigned int e_lastcount;
	bool e_toggleexport;
	bool e_togglerestart;
	bool e_nowexport;
	int e_switching;
	int e_startswitching;
	unsigned int e_switchcount;
	unsigned int e_nxtexport;
	unsigned int e_aigsat;
	unsigned int e_aigunsat;
	unsigned int e_learnedaigclause;
	double e_aigtimeout;
	int e_aigsollevel;
	double e_starttime;
#endif
	};
}

#endif
