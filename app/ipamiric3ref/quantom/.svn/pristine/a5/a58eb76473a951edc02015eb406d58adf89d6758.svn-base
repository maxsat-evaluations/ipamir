namespace quantom {

  std::vector< unsigned int > Quantom::getDecisionStack( void )
  {
	std::vector< unsigned int > decStack(m_dsEndIndex,0);
	for(unsigned int d = 1; d != m_dsEndIndex; ++d)
	  {
		decStack[d-1] = m_decisionStack[d];
	  }
	return decStack;
  }

#if 0
  void Core::MaximizeUnit( void )
  {
	// preprocess before building sorting network
	preprocess();

	std::vector< unsigned int > maximizedVariables = CreateBitonicMaximizer();
	std::vector< unsigned int > resultModel;

	std::vector< std::pair < unsigned int, std::vector< unsigned int > > > softclauses = getSoftClauses();

#ifdef DEBUG
	std::cout << __func__ << std::endl;
	for( unsigned int i = 0; i != maximizedVariables.size(); ++i )
	  {
		std::cout << maximizedVariables[i] << " ";
	  }
	std::cout << std::endl;
#endif
	std::vector<unsigned int> bestModel;

	assert(resultModel.empty());

	if (m_variablesToMaximize.size() == 0)
	  { return; } // NOTHING TO DO !

	int min = 0;
	int max = maximizedVariables.size()-1;
	int mid = 0.25*max;
	unsigned int bestKnowResult = 0;
	int solverStatus(0);
	std::cout << "\nQBF MIN/MAX : " << min << " " << (max+1);
	assert (max >= min);

	std::vector<unsigned int> assumptions;
	while (min <= max)
	  {
		assumptions.clear();
		assumptions.push_back( (maximizedVariables[mid] << 1) );
		std::cout << "\nTRY : " << (mid+1) << " with assumption : " << getLit(assumptions[0]) << std::endl;
		
		if( m_assignment[assumptions[0]] ) 	
		  { solverStatus = 10; }
		else if( m_assignment[assumptions[0]^1] ) 
		  { solverStatus = 20; }
		else
		  { 
			/* TODO */
			quantom::Quantom incquantom(1);
			//copyInstance(incquantom);
			incquantom.addUnit(assumptions[0]);
			incquantom.setPreprocessor(q_prepro);
			incquantom.setDecHeu(m_decHeu);
			incquantom.setIP(m_ip);
			incquantom.setRestartHeu(m_restartHeu);
			solverStatus = incquantom.solve(); 
			if (solverStatus == 10 )
			  { 
				bestModel = incquantom.model(); 
				// copy all units on level 0
				// only possible if instance is SAT
				std::vector< unsigned int > decstack = incquantom.getDecisionStack();
				for( unsigned int d = 1; d != decstack.size(); ++d )
				  { 
					if( decstack[d] != 0 )
					  { addUnit(Lit(decstack[d])); }
				  }
			  }
		  }

		if (solverStatus == 10) // SAT
		  {
			std::cout << "\nFound with " << (mid+1);

			for( unsigned int i = mid+1; i != maximizedVariables.size(); ++i )
			  {
				if( (bestModel[maximizedVariables[i]]&1) != 0 )
				  { 
					std::cout << " and " << (i-mid-1) << " by chance (" << i << " total)"; 
					mid = i - 1;
					break;
				  }
			  }

			std::cout << std::endl;
			min = mid + 1;
			bestKnowResult = mid+1;

			addUnit( maximizedVariables[mid] << 1 );
		  }
		else if (solverStatus == 0) // Timeout
		  {
			std::cout << "\nTimeout with " << (mid+1) << std::endl;
			break;
		  }
		else
		  {
			std::cout << "\nFailed with " << (mid+1) << std::endl;

			max = mid - 1;
			addUnit( (maximizedVariables[mid] << 1)^1);
		  }

		simplify(false);
		mid = (min+max) / 2;
		std::cout << "known bounds: (" << min << " / " << (max+1) << ")" << std::endl;
	  }

	if (bestKnowResult > 0)
	  { 
		resultModel = bestModel; 
	  }

	dumpMaxResult( resultModel, softclauses );
  }
#endif

  void Core::dumpMaxResult( const std::vector< unsigned int >& resultmodel, const std::vector< std::pair < unsigned int, std::vector< unsigned int > > >& softclauses, std::ostream& os )
  {
#ifdef DEBUG
	std::cout << std::endl << __func__ << std::endl;
#endif

	unsigned int satclauses(0);
	unsigned int unsatclauses(0);

	std::vector< unsigned int > unsatlist;

	os << std::endl << "MAX-SATISFIED CLAUSES" << std::endl;

	if( resultmodel.empty() )
	  {
		for( unsigned int v = 0; v != softclauses.size(); ++v )
		  { 
			++unsatclauses;
			unsatlist.push_back(v);
		  }
	  } 
	else 
	  {
		/*collect satisfied clauses*/
		for( unsigned int v = 0; v != softclauses.size(); ++v )
		  {
			unsigned int var = softclauses[v].first;
			// Clause satisfied 
			if( resultmodel[var] == (var<<1) )
			  {
				++satclauses;
				unsigned int pos(0);
				std::vector< unsigned int> clause = softclauses[v].second;
				while( clause[pos] != 0 )
				  {
					os << getLit(clause[pos]) << " ";
					++pos;
				  }
				os << "0; ";
			  }
			else if ( resultmodel[var] == ((var<<1)^1) )
			  {
				++unsatclauses;
				unsatlist.push_back(v);
			  }
			else
			  {  std::cout << "WARNING! No model for " << var << std::endl; }
		  }
	  }
	
	os << "number of SATClauses: " << satclauses << std::endl;
	os << "UNSATISFIED CLAUSES" << std::endl;
	/*collect unsatisfied clauses*/
	for( unsigned int v = 0; v != unsatlist.size(); ++v )
	  {
		unsigned int pos(0);
		std::vector<unsigned int> clause = softclauses[unsatlist[v]].second;

		while( clause[pos] != 0 )
		  {
			os << getLit(clause[pos]) << " ";
			++pos;
		  }
		os << "0; ";
	  }
	os << "number of UNSATClauses: " << unsatclauses << std::endl;	
  }




  // vielleicht machen... ineffiziente Version zum Vergleich 
#if 0
  std::vector<int> SatMaximizer::CreateMaximizer( std::vector<int>* variablesToMaximize )
  {
	std::vector<int> result;

	std::vector< std::vector< int > > tmpLiterals;
	tmpLiterals.resize(variablesToMaximize->size(),0);

	tmpLiterals[0].push_back( variablesToMaximize[0] );

	// FORMAT : XXXXX100000 == 6 (Position der ersten 1 von links)
	for (size_t i = 1; i < variablesToMaximize->size(); i++)
	  {
		// tmpLiterals[i] will store new results
		tmpLiterals[i].resize = new int[i + 1];

		for (size_t j = 0; j <= i; j++)
		  {
			// If literal is positive : tmpLiterals[i][j] == tmpLiterals[i-1][j-1] (right shift)
			// If literal is negative : tmpLiterals[i][j] == tmpLiterals[i-1][j] (no shift)

			// Init new Literal
			tmpLiterals[i][j] = target->new_literal();

			// If literals[i] == One ;  tmpLiterals[i-1][j+1] == tmpLiterals[i][j]
			if (j == 0)
			  {
				target->new_clause(); // literals[i] ->  tmpLiterals[i][j]
				target->add_literal(-(*variablesToMaximize)[i]);
				target->add_literal(tmpLiterals[i][j]);
				target->commit_clause();
			  }
			else
			  {
				target->insert_equality(tmpLiterals[i][j],
										tmpLiterals[i - 1][j - 1], -(*variablesToMaximize)[i]);
			  }

			// If literals[i] == Zero;  tmpLiterals[i-1][j+1] == tmpLiterals[i][j]
			if (j == i)
			  {
				target->new_clause(); // -literals[i] ->  -tmpLiterals[i][j]
				target->add_literal((*variablesToMaximize)[i]);
				target->add_literal(-tmpLiterals[i][j]);
				target->commit_clause();
			  }
			else
			  {
				target->insert_equality(tmpLiterals[i - 1][j],
										tmpLiterals[i][j], (*variablesToMaximize)[i]);
			  }

		  }
	  }

	for (size_t i = 0; i < variablesToMaximize->size(); i++)
	  {
		if (i == variablesToMaximize->size()-1)
		  {
			for (size_t j = 0; j < variablesToMaximize->size(); j++)
			  {
				result->push_back(tmpLiterals[i][j]);
			  }
		  }
		delete[] tmpLiterals[i];
	  }
	delete[] tmpLiterals;
	return result;
  }
#endif

