#include "core.hpp"

//#define IMPL_STAT

#ifdef IMPL_STAT
#include <set>
#endif

#include <deque>
#include <map>

namespace quantom {

  // Performs conflict analysis for Lifting Mode
  void Core::analyzeLifting (unsigned int* conflictingClause )
  {
#ifdef ANADEBUG
    std::cout << __func__ << std::endl;
#endif

    // Update "m_incVarActivity".
    m_incVarActivity *= m_varActMultiplier;

    // Everything OK wrt. "conflictingClause"?
    assert(conflictingClause != NULL);

    // Initialization.
    unsigned int uip(0);
    unsigned int pos(m_dsEndIndex - 1); 
    unsigned int finalmlevel(m_decisionLevel);
    unsigned int elements( 0 );
    unsigned int length( 0 );
    unsigned int lit( 0 ); 
    unsigned int size( 0 );

    std::vector<bool> checked;
    checked.resize( ((m_variables+1) << 1) , false); 

	std::vector< unsigned int > tmpconflicting;

#ifdef IMPL_STAT
    std::vector<std::set<unsigned int > > impl_levels;
    impl_levels.resize( m_variables+1 );
#endif


#ifdef ANADEBUG
    std::cout << "conflicting clause: " << std::endl;
    printClause(conflictingClause, true);
    std::cout << std::endl;
#endif

    // Do we have a binary conflicting clause?
    if (m_binConflict[0] != 0 && m_binConflict[1] != 0 )
      {

		// Get both literals of the binary conflicting clause.
		unsigned int lit0(m_binConflict[0]);
		unsigned int lit1(m_binConflict[1]);

		tmpconflicting.push_back(lit0);
		tmpconflicting.push_back(lit1);
	
		// Both "lit0" and "lit1" have to be assigned on the current decision level or we implied an universal lit.
		assert( m_level[Lit(lit0) >> 1] == m_level[Lit(lit1) >> 1] ); 

		//curDLevel = m_level[Lit(lit0) >> 1];
		//std::cout << "set curdlevel: " << curDLevel << " due to: " << getLit(lit0) << std::endl;
		finalmlevel = m_level[Lit(lit0) >> 1];

		// Reset "m_binConflict".
		m_binConflict[0] = 0;
		m_binConflict[1] = 0;

		// Update "checked".
		checked[Lit(lit0)] = true;
		checked[Lit(lit1)] = true;

		elements +=2;

		if( m_assignment[lit0] )
		  {
#ifdef ANADEBUG
			std::cout << " push into c-clause: " << getLit(lit0) << std::endl;
#endif
			m_conflictClause[size++] = lit0;
			--elements;

#ifdef IMPL_STAT
			impl_levels[lit0>>1].insert(lit1>>1);
#endif
		  }
		if( m_assignment[lit1] )
		  {
#ifdef ANADEBUG
			std::cout << " push into c-clause: " << getLit(lit1) << std::endl;;
#endif
			m_conflictClause[size++] = lit1;
			--elements;

#ifdef IMPL_STAT
			impl_levels[lit1>>1].insert(lit0>>1);
#endif
		  }

		// Analyse the next clause.
		goto NEXT_CLAUSE;
      }
    else 
      {
		unsigned int l(0);
		while( conflictingClause[l] != 0 )
		  {
			tmpconflicting.push_back(conflictingClause[l]);
			if( m_assignment[conflictingClause[l]] )
			  {
#ifdef ANADEBUG
				std::cout << " push into c-clause: " << getLit(conflictingClause[l]) << std::endl;

#endif
				m_conflictClause[size++] = conflictingClause[l];
#ifdef IMPL_STAT
				impl_levels[conflictingClause[l]>>1].insert(conflictingClause[l]>>1);
#endif
			  }
			if( m_level[conflictingClause[l]>>1] > m_level[uip>>1] )
			  { uip = conflictingClause[l]; }
			++l;
		  }
      }

    // Perform conflict analysis according to the 1UIP scheme.
    do
      {
		// Initialization.
		lit = conflictingClause[length]; 

		// Analyze the literals of the current non-binary conflicting clause.
		do
		  {
			// Get the index of "lit".
			unsigned int index(lit >> 1); 

#ifdef ANADEBUG
			std::cout << getLit(lit) << (isUniversal(lit)?" (u) ":" (e) ") << "checked: " << checked[Lit(lit)] << "," << checked[Lit(lit)^1] << " mlevel: " << m_level[index] << " qlevel: " << q_level[index] << " qreason: " << q_reason[Lit(lit)>>1];
#endif

#ifdef IMPL_STAT
			impl_levels[uip>>1].insert(lit>>1);
#endif

			// "lit" not checked so far?
			if ( !checked[lit] )
			  {
				// If we already have checked the literal with the opposite polarity, we have a tautology clause
				// This may only happen with universal literal

				// Update "checked".
				checked[lit] = true;

				if( !m_assignment[lit] && ( m_level[index] > 0 ) )
				  { 
					//std::cout << "impl " << getLit(uip) << "= " << m_level[index] << std::endl;

					// Is "lit" forced?
					if ( m_forcing[index] != NULL || m_binForcing[index] != 0 )
					  { 
			
						if( finalmlevel > m_level[index] )
						  { 
							finalmlevel = m_level[index]; 
#ifdef ANADEBUG
							std::cout << "new final mlevel: " << finalmlevel << std::endl;
#endif
						  }
			
 
						++elements;

#ifdef ANADEBUG
						std::cout << " ++el-end: " << elements;
#endif
					  }
					else if ( m_level[index] > 0 )
					  {
						// What about the decision level "lit" has been assigned on?
						// Checking the decision level on which a particular variable has been 
						// assigned, requires that assumptions are stored on decision levels 
						// greater 0. Otherwise we run into problems in the incremental mode. 
						m_conflictClause[size++] = lit; 

#ifdef IMPL_STAT
						impl_levels[lit>>1].insert(lit>>1);
#endif

#ifdef ANADEBUG
						std::cout << " push into c-clause: " << getLit(lit) << std::endl;
						std::cout << "m_conflictingclause: " << std::endl;
						for( unsigned int k = 0; k != size; ++k )
						  {
							std::cout << getLit(m_conflictClause[k]) << " ";
						  }
						std::cout << std::endl;
#endif
					  }
				  }
			  }
			  
#ifdef ANADEBUG
			std::cout << std::endl;
#endif
			// Increment "length".
			++length;

			// Get the next literal to be checked.
			lit = conflictingClause[length]; 

		  } while (lit != 0);

      NEXT_CLAUSE:

		// Determine the next clause to be processed.
		while ( !checked[ Lit(m_decisionStack[pos])^1 ] && ( m_level[Lit(m_decisionStack[pos])>>1] >= finalmlevel || isDC(m_decisionStack[pos]) ) ) 
		  { --pos; }

		if( (m_level[Lit(m_decisionStack[pos])>>1] == 0 || m_level[Lit(m_decisionStack[pos])>>1] < finalmlevel ) && !isDC(m_decisionStack[pos]) )
		  { break; }

#ifdef ANADEBUG
		std::cout << getLit(m_decisionStack[pos]) << " elements: " << elements << " checked: " << checked[Lit(m_decisionStack[pos])] << "," << checked[Lit(m_decisionStack[pos])^1] << std::endl;
#endif

		uip = m_decisionStack[pos];

#ifdef ANADEBUG
		std::cout << "next uip: " << getLit(uip) << (isUniversal(uip)?" (u) ":" (e) ") << "mlevel: " << m_level[Lit(uip)>>1] << " qlevel: " << q_level[Lit(uip)>>1] << " pos: " << pos << std::endl;
#endif

		// Do we have a binary forcing clause?
		if ( m_binForcing[uip >> 1] != 0 )
		  {
			// Get the "second" literal (not the one equal to "uip").
			unsigned int L(m_binForcing[uip >> 1]); 

#ifdef ANADEBUG
			std::cout << "is bin with " << getLit(L) << " on level " << m_level[L>>1] << std::endl;
#endif
			checked[uip] = true;

#ifdef IMPL_STAT
			impl_levels[uip>>1].insert(L>>1);
#endif

			// "L" not checked so far?
			if (!checked[L])
			  {
				// Update "checked".
				checked[L] = true;

				// Increment "elements", assuming that both literals of the binary 
				// forcing clause have been assigned on the current decision level.
				//assert(m_level[L >> 1] == curDLevel);

				if ( m_forcing[L>>1] != NULL || m_binForcing[L>>1] != 0 )
				  { 
		    
					if( finalmlevel > m_level[L>>1] )
					  { 
						finalmlevel = m_level[L>>1]; 
#ifdef ANADEBUG
						std::cout << "new final mlevel: " << finalmlevel << std::endl;
#endif
					  }
		    
 
					++elements;
#ifdef ANADEBUG
					std::cout << " ++el-end: " << elements << std::endl;
#endif
				  }
				else if ( m_level[L>>1] > 0 )
				  {
					// What about the decision level "lit" has been assigned on?
					// Checking the decision level on which a particular variable has been 
					// assigned, requires that assumptions are stored on decision levels 
					// greater 0. Otherwise we run into problems in the incremental mode. 
					m_conflictClause[size++] = L; 
#ifdef ANADEBUG
					std::cout << " push into c-clause: " << getLit(L) << std::endl;
					std::cout << "m_conflictingclause: " << std::endl;
					for( unsigned int k = 0; k != size; ++k )
					  {
						std::cout << getLit(m_conflictClause[k]) << " ";
					  }
					std::cout << std::endl;
#endif
				  }
			  }

			// Update the status variables.
			--pos;
			--elements;
			length = 0;

			// Analyse the next clause.
			goto NEXT_CLAUSE;
		  }

		// Update the status variables.
		conflictingClause = m_forcing[Lit(uip) >> 1];
		length = 0;

#ifdef ANADEBUG
		std::cout << "next conflictclause: " << std::endl;
		printClause(conflictingClause, true);
		std::cout << std::endl << "elements: " << elements << std::endl;
		std::cout << "m_conflictingclause: " << std::endl;
		for( unsigned int k = 0; k != size; ++k )
		  {
			std::cout << getLit(m_conflictClause[k]) << " ";
		  }
		std::cout << std::endl;
#endif

		if( conflictingClause == NULL )
		  {
			if (elements > 0 )
			  {
#ifdef IMPL_STAT
				impl_levels[uip>>1].insert(uip>>1);
#endif
				--pos;

				goto NEXT_CLAUSE;
			  }
			break;
		  }
		else if ( elements == 1 )
		  { ++elements; }

		--pos;
		--elements;
		  
      } while ( elements > 0 );

	m_conflictClause[size++] = 0;

	//getCompleteImplGraph( tmpconflicting );

#ifdef IMPL_STAT
    std::cout << std::endl << "forcing levels:" << std::endl;
    for( unsigned int f = 1; f != impl_levels.size(); ++f)
      {
		if( impl_levels[f].empty() )
		  { continue; }
		std::cout << "v= " << f << "(" << m_level[f] << "): ";
		for( std::set<unsigned int>::iterator g = impl_levels[f].begin(); g != impl_levels[f].end(); ++g)
		  {
			std::cout << *g << " (" << m_level[*g] << ") ";
		  }
		std::cout << std::endl;
      }
#endif
	
    return;
  }

