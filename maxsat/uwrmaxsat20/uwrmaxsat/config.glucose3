BUILD_DIR?=build
MAXPRE?=-D MAXPRE
USESCIP?=-D USE_SCIP -pthread -lmpfr
BIGWEIGHTS?=#-D BIG_WEIGHTS
MINISATP_RELSYM?=
MINISATP_REL?=-std=c++14 -O3 -D NDEBUG -Wno-strict-aliasing -D INCREMENTAL -D GLUCOSE3   $(MAXPRE) $(USESCIP) $(BIGWEIGHTS)
MINISATP_DEB?=-std=c++14 -O0 -D DEBUG  -Wno-strict-aliasing -D INCREMENTAL -D GLUCOSE3   $(MAXPRE) $(USESCIP) $(BIGWEIGHTS)
MINISATP_PRF?=-std=c++14 -O3 -D NDEBUG -Wno-strict-aliasing -D INCREMENTAL -D GLUCOSE3   $(MAXPRE) $(USESCIP) $(BIGWEIGHTS)
MINISATP_FPIC?=-fpic
MINISAT_INCLUDE?=-I/include -I/include/minisat -I../glucose-3.0
MINISAT_LIB?=-flto -L/lib -L../glucose-3.0/simp -l_release $(USESCIP)
ifneq ($(MAXPRE),)
MCL_INCLUDE?=-I../maxpre/src
MCL_LIB?=-L../maxpre/src/lib -lmaxpre
else
MCL_INCLUDE?=
MCL_LIB?=
endif
ifneq ($(USESCIP),)
MCL_INCLUDE+=-I../scipoptsuite-10.0.2/scip/src -I../scipoptsuite-10.0.2/build/scip
MCL_LIB+=-L../scipoptsuite-10.0.2/build/lib -lscip -lsoplex-pic
endif
prefix?=
